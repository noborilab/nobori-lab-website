# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# First-page PDFs and JPGs (explicitly tracked)
!public/images/publications/first-pages/*.pdf
!public/images/publications/first-pages/*.jpg

# Large media
public/images/projects/phytomap.m4v
*.heic
*.HEIC

# Inbox binaries (processed and moved by Claude; .md files are tracked)
inbox/papers/*
inbox/members/*
inbox/gallery/*
!inbox/papers/.gitkeep
!inbox/members/.gitkeep
!inbox/gallery/.gitkeep
